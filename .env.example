GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

LOKI_PORT=3100
PROMETHEUS_PORT=9090
TEMPO_HTTP_PORT=3200
ALLOY_UI_PORT=12345
ALLOY_OTLP_GRPC_PORT=4317
ALLOY_OTLP_HTTP_PORT=4318

PORTAL_ENVIRONMENT=local

# Use 8080 when Hub Core runs directly through Maven/IDE.
# Use 8081 when Hub Core runs through docker-compose.all.yml or docker-compose.gateway-core.yml.
HUB_METRICS_TARGET=host.docker.internal:8081
HUB_OTLP_HTTP_ENDPOINT=http://host.docker.internal:4318/v1/traces

GATEWAY_METRICS_TARGET=host.docker.internal:8090
CHECKLIST_METRICS_TARGET=host.docker.internal:8082
SEAT_MAP_METRICS_TARGET=host.docker.internal:8083
COMUNICADOS_METRICS_TARGET=host.docker.internal:8084
